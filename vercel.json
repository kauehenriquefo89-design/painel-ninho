{
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/callback",
      "dest": "/api/callback.js"
    },
    {
      "src": "/api/store",
      "dest": "/api/store.js"
    },
    {
      "src": "/api/pluggy",
      "dest": "/api/pluggy.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/api.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}